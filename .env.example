# MP Search Configuration
# ──────────────────────────────────────────────
# This file is an EXAMPLE. On first launch, mp-search will guide you through
# an interactive setup wizard and save your config to:
#
#   ~/.config/mp-search/config.env
#
# You can also set these as environment variables directly.
# ──────────────────────────────────────────────

# Materials Project API Key (required)
# Get yours at: https://next-gen.materialsproject.org/api
MP_API_KEY=""

# Export directory for POSCAR / CIF / JSON files
# Default: ~/mp-search-exports
MP_EXPORT_DIR="~/mp-search-exports"

# Language: "en" (English, default) or "zh" (中文)
MP_SEARCH_LANG="en"
